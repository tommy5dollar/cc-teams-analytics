# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Dashboard (Next.js) ───────────────────────────────────────────────────────
# These are read at runtime from the container environment.
# For local dev they're set automatically from the compose network.
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=otel

# ── CI/CD ─────────────────────────────────────────────────────────────────────
# Set these in GitHub Actions secrets, not here.
# DEPLOY_HOST=your.server.com
# DEPLOY_USER=deploy
# DEPLOY_SSH_KEY=<private key>
# DEPLOY_PATH=/opt/cc-teams-analytics
