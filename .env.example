# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_USER=otel
CLICKHOUSE_PASSWORD=changeme

# ── OTLP auth ─────────────────────────────────────────────────────────────────
# Bearer token CC clients must send: Authorization: Bearer <token>
# Generate with: openssl rand -hex 32
OTLP_BEARER_TOKEN=changeme

# ── Caddy (production only) ───────────────────────────────────────────────────
# Domain pointing at this server — Caddy auto-provisions TLS
OTEL_DOMAIN=otel.yourcompany.com

# ── Dashboard (Next.js) ───────────────────────────────────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=otel

# ── CI/CD ─────────────────────────────────────────────────────────────────────
# Set these in GitHub Actions secrets, not here.
# DEPLOY_HOST=your.server.com
# DEPLOY_USER=deploy
# DEPLOY_SSH_KEY=<private key>
# DEPLOY_PATH=/opt/cc-teams-analytics
